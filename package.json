{
  "name": "broncomparts-desktop",
  "private": true,
  "version": "1.0.0",
  "description": "База данных BroncomParts",
  "author": "Богдан",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.473.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-router-dom": "^7.1.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.0.0",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "tailwindcss": "4.0.0",
    "typescript": "5.7.3",
    "vite": "6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.broncomparts.app",
    "productName": "BroncomParts",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icon.ico" 
    ],
    "win": {
      "target": ["portable", "dir"],
      "icon": "icon.ico"
    }
  }
}